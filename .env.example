# Server 
PORT=3000

# Authentication 
AUTH_TOKEN=your-secret-auth-token-here

# Mixpanel 
MIXPANEL_TOKEN=your-mixpanel-project-token-here

# Pipeline Tuning (optional) 
# CHANNEL_BUFFER_SIZE=100000   # buffered channel capacity
# BATCH_SIZE=50                # events per batch before flush
# FLUSH_INTERVAL=2s            # max wait before flush (Go duration)
# WORKER_COUNT=4               # background flush goroutines
